{
  "name": "arrivio-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Arrivio airport passenger services marketplace monorepo.",
  "scripts": {
    "dev:web": "pnpm --filter @arrivio/web dev",
    "dev:admin": "pnpm --filter @arrivio/admin dev",
    "dev:provider": "pnpm --filter @arrivio/provider dev",
    "dev:mobile": "pnpm --filter @arrivio/mobile start",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.18.0"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}

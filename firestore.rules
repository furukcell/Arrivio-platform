rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(userPath());
    }

    function appUser() {
      return get(userPath()).data;
    }

    function isAdmin() {
      return hasUserProfile() && appUser().role == "admin";
    }

    function isProvider() {
      return hasUserProfile() && appUser().role == "provider" && appUser().providerId is string;
    }

    function providerId() {
      return appUser().providerId;
    }

    function isAssignedProvider() {
      return isProvider() && resource.data.assignedProviderId == providerId();
    }

    function isOwnProviderPrice() {
      return isProvider() && resource.data.providerId == providerId();
    }

    function isOwnProviderPriceCreate() {
      return isProvider() && request.resource.data.providerId == providerId();
    }

    function isPublicActiveVerifiedPrice() {
      return resource.data.isActive == true && resource.data.isVerified == true;
    }

    function providerStatusAllowed() {
      return request.resource.data.status in ["confirmed", "passenger_waiting", "passenger_picked_up", "completed", "cancelled"];
    }

    function providerTransferUpdateOnly() {
      return request.resource.data.diff(resource.data).affectedKeys().hasOnly(["status", "providerNote", "estimatedTotalPrice", "updatedAt"]);
    }

    function validPublicLanguage() {
      return request.resource.data.language == "tr" || request.resource.data.language == "en";
    }

    function publicRequestBaseAllowed(expectedType) {
      return request.resource.data.type == expectedType
        && request.resource.data.status == "new"
        && request.resource.data.commissionStatus == "pending"
        && request.resource.data.currency == "TRY"
        && request.resource.data.requestCode is string
        && request.resource.data.passengerName is string
        && request.resource.data.passengerPhone is string
        && request.resource.data.airportCode is string
        && validPublicLanguage()
        && !request.resource.data.keys().hasAny(["assignedProviderId", "providerName", "providerNote", "adminNote", "commissionAmount"]);
    }

    function publicTransferCreateAllowed() {
      return publicRequestBaseAllowed("transfer")
        && request.resource.data.destination is string
        && request.resource.data.passengers is int
        && request.resource.data.passengers >= 1
        && request.resource.data.transferDirection in ["from_airport", "to_airport"];
    }

    function publicCarRentalCreateAllowed() {
      return publicRequestBaseAllowed("carRental")
        && request.resource.data.pickupLocation is string
        && request.resource.data.pickupDate is string
        && request.resource.data.dropoffDate is string;
    }

    function publicHotelCreateAllowed() {
      return publicRequestBaseAllowed("hotel")
        && request.resource.data.checkInDate is string
        && request.resource.data.checkOutDate is string
        && request.resource.data.guests is int
        && request.resource.data.guests >= 1;
    }

    function publicTicketCreateAllowed() {
      return publicRequestBaseAllowed("ticket")
        && request.resource.data.fromAirportOrCity is string
        && request.resource.data.toAirportOrCity is string
        && request.resource.data.departureDate is string
        && request.resource.data.passengers is int
        && request.resource.data.passengers >= 1;
    }

    match /users/{userId} {
      allow read: if isAdmin() || (signedIn() && request.auth.uid == userId);
      allow create, update, delete: if isAdmin();
    }

    match /providers/{providerDocId} {
      allow read: if isAdmin() || (isProvider() && providerId() == providerDocId);
      allow create, update, delete: if isAdmin();
    }

    match /transferRoutePrices/{priceId} {
      allow read: if isAdmin() || isOwnProviderPrice() || isPublicActiveVerifiedPrice();
      allow create: if isAdmin() || isOwnProviderPriceCreate();
      allow update, delete: if isAdmin() || isOwnProviderPrice();
    }

    match /carRentalDailyPrices/{priceId} {
      allow read: if isAdmin() || isOwnProviderPrice() || isPublicActiveVerifiedPrice();
      allow create: if isAdmin() || isOwnProviderPriceCreate();
      allow update, delete: if isAdmin() || isOwnProviderPrice();
    }

    match /hotelNightlyPrices/{priceId} {
      allow read: if isAdmin() || isOwnProviderPrice() || isPublicActiveVerifiedPrice();
      allow create: if isAdmin() || isOwnProviderPriceCreate();
      allow update, delete: if isAdmin() || isOwnProviderPrice();
    }

    match /transferRequests/{requestId} {
      allow create: if publicTransferCreateAllowed() || isAdmin();
      allow read: if isAdmin() || isAssignedProvider();
      allow update: if isAdmin() || (isAssignedProvider() && providerTransferUpdateOnly() && providerStatusAllowed());
      allow delete: if isAdmin();
    }

    match /carRentalRequests/{requestId} {
      allow create: if publicCarRentalCreateAllowed() || isAdmin();
      allow read, update, delete: if isAdmin();
    }

    match /hotelRequests/{requestId} {
      allow create: if publicHotelCreateAllowed() || isAdmin();
      allow read, update, delete: if isAdmin();
    }

    match /ticketRequests/{requestId} {
      allow create: if publicTicketCreateAllowed() || isAdmin();
      allow read, update, delete: if isAdmin();
    }

    match /qrSources/{sourceId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /qrEvents/{eventId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /commissions/{commissionId} {
      allow read, write: if isAdmin();
    }

    match /adminLogs/{logId} {
      allow create, read: if isAdmin();
      allow update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
